# Engine-0 배치 — 매 3시간마다 (0분, 예: 00:00, 03:00, 06:00 …)
# 적용: 수집을 돌릴 OS 사용자(예: ubuntu)로 로그인 후 `crontab -e` 에 아래 블록 추가
#       (저장소는 crossword 루트 아래 harness-factory 로 옮겨짐 — 2026-04)
#
# CRON_TZ: 아래 스케줄을 한국 표준시(KST)로 해석 (서버가 UTC여도 동일 시각에 실행)
#
# SHELL=/bin/bash
# PATH=/usr/local/bin:/usr/bin:/bin

CRON_TZ=Asia/Seoul
0 */3 * * * HARNESS_LOG_DIR=/home/ubuntu/crossword/harness-factory/logs HARNESS_ENRICH_LIMIT=30 /home/ubuntu/crossword/harness-factory/engine-0-scanner/daily_engine0_run.sh >> /home/ubuntu/crossword/harness-factory/logs/engine0-cron.log 2>&1
